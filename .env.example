# Copy to .env (gitignored) for local `netlify dev`, and set the same vars in
# the Netlify dashboard (Site settings → Environment variables) for production.

# Required — your API key from https://build.nvidia.com (kept server-side only).
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — override the model. Default: meta/llama-3.3-70b-instruct
# NVIDIA_MODEL=meta/llama-3.3-70b-instruct
